{
  "manifest_version": 3,
  "name": "CssLoader",
  "version": "1.0",

  "description": "Loads predefined css to website",

  "icons": {
    "48": "icons/AHHH.png"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "CSS Injector"
  },
  "web_accessible_resources": [{
    "resources": ["styles/*.css"],
    "matches": ["<all_urls>"]
  }]
}