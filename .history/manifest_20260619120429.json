{
  "manifest_version": 3,
  "name": "CssLoader",
  "version": "1.0",

  "description": "Loads predefined css to website",

  "icons": {
    "48": "icons/AHHH.png"
  },
  "permissions": ["tabs"],
  "web_accessible_resources": [
    {
      "matches": ["*://*/*"],
      "js": ["CssLoader.js"]
    }
  ]
}