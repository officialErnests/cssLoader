{
    "manifest_version": 3,
    "name": "CssLoader",
    "version": "1.0",

    "description": "Loads predefined css to website",
    "browser_specific_settings": {
        "gecko": {
            "id": "NuhUh@noobEvil.Corp",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "icons": {
        "48": "icons/AHHH.png"
    },
    "permissions": ["downloads", "storage", "tabs", "scripting"],
    "host_permissions": [
        "<all_urls>"
    ],
    "content_scripts": [
        {
            "matches": ["*://*/*"]
        }
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "cssloader.js"
    }
    "web_accessible_resources": [{
        "resources": ["styles/*.css"],
        "matches": ["<all_urls>"]
    }]
}