{
    "manifest_version": 3,
    "name": "CssLoader",
    "version": "1.0",

    "description": "Loads predefined css to website",
    "browser_specific_settings": {
    "gecko": {
        "id": "borderify@mozilla.org",
        "data_collection_permissions": {
            "required": ["none"]
        }
    }
    },
    "icons": {
    "48": "icons/AHHH.png"
    },
    "permissions": ["tabs"],
    "content_scripts": [
    {
        "matches": ["*://*/*"],
        "js": ["cssloader.js"]
    }
    ]
}