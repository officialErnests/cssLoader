{
    "manifest_version": 3,
    "name": "CssLoader",
    "version": "1.0",

    "description": "Loads predefined css to website",
    "browser_specific_settings": {
        "gecko": {
            "id": "n0o0b090lv@gmail.com",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "icons": {
        "48": "icons/AHHH.png"
    },
    "permissions": ["storage", "tabs", "scripting"],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "background": {
        "scripts": ["cssloader.js"]
    }
}